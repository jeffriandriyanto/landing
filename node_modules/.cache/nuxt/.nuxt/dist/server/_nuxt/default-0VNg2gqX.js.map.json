{"file":"default-0VNg2gqX.js","mappings":";;;;;;;;;;;;;;;AA8DA,UAAM,SAAS,IAAwB,IAAI;AAC3C,UAAM,WAAW,IAAI,KAAK;AAE1B,UAAM,WAAW;AAAA,MACf,EAAE,IAAI,SAAS,OAAO,QAAA;AAAA,MACtB,EAAE,IAAI,cAAc,OAAO,aAAA;AAAA,MAC3B,EAAE,IAAI,QAAQ,OAAO,QAAA;AAAA,IAAQ;;;iBAlEvB;AAAA,QAAJ,KAAI;AAAA,QACJ,OAAK,CAAC,+DACEA,MAAA,QAAA,IAAQ,eAAA,MAAA;AAAA,MAAA;AA0BKC,oBAAA,WAAR,SAAI;iCAEV,QAAI,IAAM,KAAK,EAAE,EAAA,sJAMfC,eAAA,KAAK,KAAK;;;;;;;;;;;;;;;;ICrCb,IAAG;AAAA,IAAU,OAAM;AAAA,qzFAyDDA,gBAAA,oBAAA,KAAI,GAAG,YAAW,CAAA;;;;;;;;;;;;;ACzDvC,QAAA,OAAAC,eAAAC,WAAA,EAAA,OAAM,sCAAkC,MAAA,CAAA,CAAA,GAAA;;;;;;;;;;;;;;;","names":["_unref","_ssrRenderList","_ssrInterpolate","_ssrRenderAttrs","_mergeProps"],"sources":["../../../../../../../app/components/NavBar.vue","../../../../../../../app/components/FooterSection.vue","../../../../../../../app/layouts/default.vue"],"sourcesContent":["<template>\n  <nav\n    ref=\"navRef\"\n    class=\"fixed top-0 left-0 right-0 z-50 transition-all duration-500\"\n    :class=\"scrolled ? 'glass py-3' : 'py-5'\"\n  >\n    <div class=\"max-w-7xl mx-auto px-6 flex items-center justify-between\">\n      <!-- Logo -->\n      <a\n        href=\"#hero\"\n        class=\"magnetic-wrap group flex items-center gap-3\"\n        @mouseenter=\"onMagnetic\"\n        @mouseleave=\"offMagnetic\"\n        @mousemove=\"moveMagnetic\"\n      >\n        <div\n          class=\"w-8 h-8 rounded-md bg-accent/10 border border-accent/20 flex items-center justify-center group-hover:bg-accent/20 transition-all duration-300\"\n        >\n          <span class=\"text-accent font-mono font-bold text-sm\">JA</span>\n        </div>\n        <span\n          class=\"text-silver-bright font-medium text-sm tracking-wide hidden sm:block\"\n        >\n          jeffri<span class=\"text-accent\">.</span>dev\n        </span>\n      </a>\n\n      <!-- Navigation Links -->\n      <div class=\"hidden md:flex items-center gap-8\">\n        <a\n          v-for=\"link in navLinks\"\n          :key=\"link.id\"\n          :href=\"`#${link.id}`\"\n          class=\"magnetic-wrap text-silver-muted hover:text-silver-bright text-sm font-medium tracking-wide transition-colors duration-300 relative group\"\n          @mouseenter=\"onMagnetic\"\n          @mouseleave=\"offMagnetic\"\n          @mousemove=\"moveMagnetic\"\n        >\n          {{ link.label }}\n          <span\n            class=\"absolute -bottom-1 left-0 w-0 h-px bg-accent group-hover:w-full transition-all duration-300\"\n          />\n        </a>\n      </div>\n\n      <!-- CTA -->\n      <a\n        href=\"#contact\"\n        class=\"magnetic-wrap px-5 py-2 text-sm font-medium text-void bg-accent rounded-md hover:bg-accent-glow transition-all duration-300 hover:shadow-[0_0_25px_rgba(0,220,160,0.3)]\"\n        @mouseenter=\"onMagnetic\"\n        @mouseleave=\"offMagnetic\"\n        @mousemove=\"moveMagnetic\"\n      >\n        Let's Talk\n      </a>\n    </div>\n  </nav>\n</template>\n\n<script setup lang=\"ts\">\nimport { gsap } from \"gsap\";\n\nconst navRef = ref<HTMLElement | null>(null);\nconst scrolled = ref(false);\n\nconst navLinks = [\n  { id: \"works\", label: \"Works\" },\n  { id: \"experience\", label: \"Experience\" },\n  { id: \"tech\", label: \"Stack\" },\n];\n\n// Magnetic hover effect\nfunction onMagnetic(e: MouseEvent) {\n  const el = e.currentTarget as HTMLElement;\n  gsap.to(el, { scale: 1.05, duration: 0.3, ease: \"power2.out\" });\n}\n\nfunction offMagnetic(e: MouseEvent) {\n  const el = e.currentTarget as HTMLElement;\n  gsap.to(el, {\n    scale: 1,\n    x: 0,\n    y: 0,\n    duration: 0.5,\n    ease: \"elastic.out(1, 0.5)\",\n  });\n}\n\nfunction moveMagnetic(e: MouseEvent) {\n  const el = e.currentTarget as HTMLElement;\n  const rect = el.getBoundingClientRect();\n  const x = (e.clientX - rect.left - rect.width / 2) * 0.2;\n  const y = (e.clientY - rect.top - rect.height / 2) * 0.2;\n  gsap.to(el, { x, y, duration: 0.3, ease: \"power2.out\" });\n}\n\nonMounted(() => {\n  const onScroll = () => {\n    scrolled.value = window.scrollY > 50;\n  };\n  window.addEventListener(\"scroll\", onScroll, { passive: true });\n  onUnmounted(() => window.removeEventListener(\"scroll\", onScroll));\n});\n</script>\n","<template>\n  <footer id=\"contact\" class=\"relative py-24 px-6 border-t border-void-300\">\n    <div class=\"max-w-7xl mx-auto\">\n      <div class=\"grid md:grid-cols-2 gap-16\">\n        <div>\n          <span class=\"text-xs font-mono text-accent tracking-widest uppercase\"\n            >Connect</span\n          >\n          <h2\n            class=\"text-3xl sm:text-4xl font-bold text-white mt-3 tracking-tight\"\n          >\n            Let's Build<br />Something Great\n          </h2>\n          <p class=\"text-silver-muted mt-4 max-w-md leading-relaxed\">\n            Looking for a frontend architect who can turn complex requirements\n            into elegant, high-performance solutions? Let's talk.\n          </p>\n          <div class=\"flex items-center gap-4 mt-8\">\n            <a\n              href=\"mailto:jeffriandriyanto.fe@gmail.com\"\n              class=\"px-6 py-3 bg-accent text-void font-semibold rounded-lg hover:bg-accent-glow transition-all duration-300 hover:shadow-[0_0_30px_rgba(0,220,160,0.25)] text-sm\"\n            >\n              jeffriandriyanto.fe@gmail.com\n            </a>\n            <a\n              href=\"https://linkedin.com/in/jeffriandriyanto\"\n              target=\"_blank\"\n              rel=\"noopener\"\n              class=\"w-10 h-10 rounded-lg glass flex items-center justify-center text-silver-muted hover:text-accent transition-colors duration-300\"\n            >\n              <svg class=\"w-5 h-5\" fill=\"currentColor\" viewBox=\"0 0 24 24\">\n                <path\n                  d=\"M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z\"\n                />\n              </svg>\n            </a>\n            <a\n              href=\"https://github.com/jeffriandriyanto\"\n              target=\"_blank\"\n              rel=\"noopener\"\n              class=\"w-10 h-10 rounded-lg glass flex items-center justify-center text-silver-muted hover:text-accent transition-colors duration-300\"\n            >\n              <svg class=\"w-5 h-5\" fill=\"currentColor\" viewBox=\"0 0 24 24\">\n                <path\n                  d=\"M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z\"\n                />\n              </svg>\n            </a>\n          </div>\n        </div>\n        <div class=\"flex flex-col justify-end items-start md:items-end\">\n          <div class=\"text-right\">\n            <p class=\"text-silver-dim text-sm\">Based in Salatiga, Indonesia</p>\n            <p class=\"text-silver-dim text-sm mt-1\">Creetech</p>\n            <div\n              class=\"w-16 h-px bg-gradient-to-r from-transparent to-accent/30 mt-4 ml-auto\"\n            />\n            <p class=\"text-silver-dim text-xs mt-4 font-mono\">\n              &copy; {{ new Date().getFullYear() }} Jeffri Andriyanto\n            </p>\n            <p class=\"text-void-400 text-xs mt-1 font-mono\">\n              Built with Nuxt 4 + GSAP\n            </p>\n          </div>\n        </div>\n      </div>\n    </div>\n  </footer>\n</template>\n\n<script setup lang=\"ts\"></script>\n","<template>\n  <div class=\"min-h-screen bg-void text-silver\">\n    <NavBar />\n    <main>\n      <slot />\n    </main>\n    <FooterSection />\n  </div>\n</template>\n\n<script setup lang=\"ts\"></script>\n"],"version":3}